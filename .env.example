# AQMesh API credentials (obtain from your AQMesh API access contract).
# You must authenticate and change password first at:
# https://test.aqmeshdata.net and/or https://aqmeshdata.net
AQMESH_USERNAME=your-api-username
AQMESH_PASSWORD=your-api-password

# Which AQMesh environment to target: "test" or "prod".
#   test -> https://apitest.aqmeshdata.net/api
#   prod -> https://api.aqmeshdata.net/api
AQMESH_ENVIRONMENT=test

# Root directory of the shared storage volume where raw + cleaned data are written.
# In production this is the folder mounted on the VM.
AQMESH_DATA_ROOT=./data

# Reading request defaults (see API manual section 4.10).
#   UNITS: "01" = Celsius + ug/m3 (recommended). "00" ppb, "10"/"11" Fahrenheit variants.
#   TPC: 1 to include Total Particle Count in particle output, else 0.
#   VERSION: 0 standard, 1 to include Ethylene Oxide.
AQMESH_UNITS=01
AQMESH_TPC=1
AQMESH_VERSION=0

# HTTP behaviour.
AQMESH_REQUEST_TIMEOUT=60
AQMESH_MAX_RETRIES=4

# Prefect telemetry
# https://docs.prefect.io/v3/concepts/telemetry
PREFECT_SERVER_ANALYTICS_ENABLED=false
DO_NOT_TRACK=1
